{
  "name": "vscode-fff",
  "displayName": "FFF for VS Code",
  "description": "Workspace-scoped fff-mcp for Copilot Chat / language models. Indexes the current project instead of your home directory.",
  "version": "0.0.1",
  "publisher": "codehz",
  "engines": {
    "vscode": "^1.125.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codehz/vscode-fff.git"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "fff",
    "mcp",
    "search",
    "grep",
    "copilot",
    "language-model"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "vscode-fff.servers",
        "label": "FFF"
      }
    ],
    "commands": [
      {
        "command": "vscode-fff.showStatus",
        "title": "FFF: Show MCP Server Status"
      }
    ],
    "configuration": {
      "title": "FFF",
      "properties": {
        "fff.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Provide an FFF MCP server for this workspace folder."
        },
        "fff.binaryPath": {
          "type": "string",
          "default": "fff-mcp",
          "scope": "machine-overridable",
          "markdownDescription": "Path to the `fff-mcp` executable. Defaults to resolving `fff-mcp` from `PATH`."
        },
        "fff.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--no-update-check"
          ],
          "scope": "resource",
          "markdownDescription": "Extra CLI arguments appended after the workspace path. Example: `[\"--no-warmup\"]`."
        },
        "fff.frecencyDb": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional path passed as `--frecency-db`. Empty uses the fff-mcp default."
        },
        "fff.historyDb": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional path passed as `--history-db`. Empty uses the fff-mcp default."
        },
        "fff.logFile": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional path-shape hint for `--log-file`. Empty uses the fff-mcp default."
        },
        "fff.logLevel": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ],
          "scope": "resource",
          "markdownDescription": "Optional `--log-level`. Empty uses the fff-mcp default."
        },
        "fff.maxCachedFiles": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "scope": "resource",
          "markdownDescription": "Optional `--max-cached-files` limit. `null` keeps the fff-mcp default."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
